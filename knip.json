{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "bin/*.js",
    "lib/cli/*.js",
    "lib/migrations/index.js",
    ".agents/scripts/*.js",
    "scripts/**/*.js",
    "tests/**/*.{js,mjs,cjs}",
    "*.config.{js,mjs,cjs}",
    ".husky/**"
  ],
  "project": [
    "bin/**/*.js",
    "lib/**/*.js",
    ".agents/scripts/**/*.js",
    "scripts/**/*.js",
    "tests/**/*.{js,mjs,cjs}"
  ],
  "ignore": [
    "node_modules/**",
    ".worktrees/**",
    "coverage/**",
    "temp/**",
    "baselines/**",
    ".claude/**",
    "lib/**/__tests__/**"
  ],
  "ignoreDependencies": ["typescript", "c8"],
  "rules": {
    "files": "warn",
    "duplicates": "off",
    "dependencies": "off",
    "devDependencies": "off",
    "binaries": "off",
    "unlisted": "off",
    "unresolved": "off",
    "exports": "error",
    "types": "error",
    "nsExports": "off",
    "nsTypes": "off",
    "enumMembers": "error"
  }
}
