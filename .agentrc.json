{
  "$schema": "./.agents/schemas/agentrc.schema.json",
  "project": {
    "baseBranch": "main",
    "paths": {
      "agentRoot": ".agents",
      "docsRoot": "docs",
      "tempRoot": "temp"
    },
    "docsContextFiles": [
      "architecture.md",
      "data-dictionary.md",
      "decisions.md",
      "patterns.md"
    ],
    "commands": {
      "lintBaseline": "npm run lint",
      "test": "npm test",
      "typecheck": "node --version"
    }
  },
  "github": {
    "owner": "dsj1984",
    "repo": "mandrel",
    "projectNumber": 1,
    "projectOwner": "dsj1984",
    "operatorHandle": "@dsj1984",
    "notifications": {
      "mentionOperator": false,
      "commentEvents": ["state-transition", "story-merged", "operator-message"],
      "webhookEvents": [
        "epic-started",
        "epic-progress",
        "epic-blocked",
        "epic-unblocked",
        "epic-complete"
      ]
    }
  },
  "planning": {
    "maxTickets": 60,
    "riskHeuristics": [
      "Destructive or irreversible data mutations (dropping tables, deleting rows without soft-delete or backup, truncating production state).",
      "Modifications to shared security or auth infrastructure (IAM policies, auth middleware, session or token handling, secret rotation).",
      "Changes to CI/CD, deployment pipelines, or release gating that could disable safety checks or ship unverified code to production.",
      "Monorepo-wide AST or text replacements touching overlapping files in parallel (catastrophic merge-conflict risk across concurrent agents).",
      "Schema migrations that rewrite existing rows or drop columns without a backfill or rollback plan."
    ]
  },
  "delivery": {
    "execution": { "timeoutMs": 600000 },
    "maxTokenBudget": 200000,
    "docsFreshness": {
      "paths": ["README.md", "docs/CHANGELOG.md"]
    },
    "deliverRunner": {
      "concurrencyCap": 3,
      "progressReportIntervalSec": 300
    },
    "worktreeIsolation": {
      "enabled": true,
      "root": ".worktrees",
      "nodeModulesStrategy": "symlink",
      "primeFromPath": ".",
      "allowSymlinkOnWindows": true,
      "reapOnSuccess": true,
      "reapOnCancel": true,
      "bootstrapFiles": [".env"]
    },
    "signals": {
      "hotspot": { "p95Multiplier": 1.25 },
      "rework": { "editsPerFile": 5 },
      "retry": { "repeatCount": 3 }
    },
    "quality": {
      "gateScoping": { "scope": "diff", "diffRef": "main" },
      "gates": {
        "lint": {
          "enabled": true,
          "baselinePath": "baselines/lint.json",
          "tolerance": { "kind": "absolute", "value": 0 },
          "floors": { "*": { "errors": 0 } }
        },
        "coverage": {
          "enabled": true,
          "baselinePath": "baselines/coverage.json",
          "tolerance": { "kind": "absolute", "value": 0 },
          "floors": { "*": { "lines": 40, "branches": 40, "functions": 0 } },
          "coveragePath": "coverage/coverage-final.json"
        },
        "crap": {
          "enabled": true,
          "baselinePath": "baselines/crap.json",
          "tolerance": { "kind": "absolute", "value": 0.05 },
          "floors": { "*": { "crap": 30 } },
          "targetDirs": [".agents/scripts"],
          "newMethodCeiling": 30,
          "requireCoverage": true,
          "friction": { "markerKey": "crap-baseline-regression" },
          "refreshTag": "baseline-refresh:"
        },
        "maintainability": {
          "enabled": true,
          "baselinePath": "baselines/maintainability.json",
          "tolerance": { "kind": "absolute", "value": 0.5 },
          "floors": { "*": { "maintainability": 0 } },
          "targetDirs": [".agents/scripts", "tests"]
        }
      }
    }
  }
}
