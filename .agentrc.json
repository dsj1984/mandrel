{
  "$schema": "./.agents/schemas/agentrc.schema.json",
  "project": {
    "paths": {
      "agentRoot": ".agents",
      "docsRoot": "docs",
      "tempRoot": "temp"
    },
    "commands": {
      "lintBaseline": "npm run lint",
      "typecheck": "node --version"
    }
  },
  "github": {
    "owner": "dsj1984",
    "repo": "mandrel",
    "projectNumber": 1,
    "operatorHandle": "@[USERNAME]",
    "branchProtection": {
      "requiredChecks": [
        { "name": "lint", "cmd": ["npm", "run", "lint"] },
        { "name": "test", "cmd": ["npm", "test"] },
        {
          "name": "baselines",
          "cmd": ["node", ".agents/scripts/check-baselines.js"]
        },
        {
          "name": "lifecycle-doc-drift",
          "cmd": ["node", ".agents/scripts/check-lifecycle-doc-drift.js"]
        }
      ]
    }
  },
  "delivery": {
    "docsFreshness": {
      "paths": ["README.md", "docs/CHANGELOG.md"]
    },
    "quality": {
      "gates": {
        "crap": {
          "floors": { "*": { "max": 40 } },
          "targetDirs": [".agents/scripts"]
        },
        "maintainability": {
          "floors": { "*": { "min": 34 } },
          "targetDirs": [".agents/scripts", "tests"],
          "tolerance": { "kind": "absolute", "value": 12 }
        },
        "duplication": {
          "floors": { "*": { "percentage": 25 } },
          "targetDirs": [".agents/scripts"],
          "tolerance": { "kind": "absolute", "value": 1 }
        }
      }
    }
  }
}
