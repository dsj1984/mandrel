{
  "$schema": "./.agents/schemas/agentrc.schema.json",
  "project": {
    "baseBranch": "main",
    "paths": {
      "agentRoot": ".agents",
      "docsRoot": "docs",
      "tempRoot": "temp"
    },
    "docsContextFiles": [
      "architecture.md",
      "data-dictionary.md",
      "decisions.md",
      "patterns.md"
    ],
    "commands": {
      "lintBaseline": "npm run lint",
      "test": "npm test",
      "typecheck": "node --version"
    }
  },
  "github": {
    "owner": "dsj1984",
    "repo": "mandrel",
    "projectNumber": 1,
    "projectOwner": "dsj1984",
    "operatorHandle": "@dsj1984",
    "notifications": {
      "mentionOperator": false,
      "commentEvents": ["state-transition", "story-merged", "operator-message"],
      "webhookEvents": [
        "epic-started",
        "epic-progress",
        "epic-blocked",
        "epic-unblocked",
        "epic-complete"
      ]
    }
  },
  "planning": {
    "riskHeuristics": [
      "Destructive or irreversible data mutations (dropping tables, deleting rows without soft-delete or backup, truncating production state).",
      "Modifications to shared security or auth infrastructure (IAM policies, auth middleware, session or token handling, secret rotation).",
      "Changes to CI/CD, deployment pipelines, or release gating that could disable safety checks or ship unverified code to production.",
      "Monorepo-wide AST or text replacements touching overlapping files in parallel (catastrophic merge-conflict risk across concurrent agents).",
      "Schema migrations that rewrite existing rows or drop columns without a backfill or rollback plan."
    ]
  },
  "delivery": {
    "docsFreshness": {
      "paths": ["README.md", "docs/CHANGELOG.md"]
    },
    "deliverRunner": {
      "progressReportIntervalSec": 300
    },
    "worktreeIsolation": {
      "enabled": true,
      "root": ".worktrees",
      "nodeModulesStrategy": "symlink",
      "primeFromPath": ".",
      "allowSymlinkOnWindows": true,
      "reapOnSuccess": true,
      "reapOnCancel": true,
      "bootstrapFiles": [".env"]
    },
    "quality": {
      "gates": {
        "coverage": {
          "floors": { "*": { "lines": 40, "branches": 40, "functions": 0 } }
        },
        "crap": {
          "floors": { "*": { "crap": 30 } },
          "targetDirs": [".agents/scripts"]
        },
        "maintainability": {
          "floors": { "*": { "maintainability": 0 } },
          "targetDirs": [".agents/scripts", "tests"]
        }
      }
    }
  }
}
