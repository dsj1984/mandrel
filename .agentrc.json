{
  "$schema": "./.agents/schemas/agentrc.schema.json",
  "project": {
    "paths": {
      "agentRoot": ".agents",
      "docsRoot": "docs",
      "tempRoot": "temp"
    },
    "commands": {
      "lintBaseline": "npm run lint",
      "typecheck": "node --version"
    }
  },
  "github": {
    "owner": "dsj1984",
    "repo": "mandrel",
    "projectNumber": 1,
    "projectOwner": "dsj1984",
    "operatorHandle": "@dsj1984",
    "branchProtection": {
      "requiredChecks": [
        { "name": "lint", "cmd": ["npm", "run", "lint"] },
        { "name": "test", "cmd": ["npm", "test"] },
        { "name": "baselines", "cmd": ["node", ".agents/scripts/check-baselines.js"] }
      ]
    }
  },
  "delivery": {
    "docsFreshness": {
      "paths": ["README.md", "docs/CHANGELOG.md"]
    },
    "quality": {
      "gates": {
        "crap": {
          "floors": { "*": { "max": 999 } },
          "targetDirs": [".agents/scripts"]
        },
        "maintainability": {
          "floors": { "*": { "min": 0 } },
          "targetDirs": [".agents/scripts", "tests"]
        }
      }
    }
  }
}
