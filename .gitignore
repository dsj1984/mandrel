.env
.env.local
node_modules
dist
.DS_Store
*.log

# NOTE: This is the Mandrel framework SOURCE repo, where ./.agents/ IS the
# committed product — so it is deliberately NOT ignored here (Story #3489).
# A blanket `/.agents/` ignore (correct for a *consumer* project, where
# ./.agents/ is a working copy materialized from node_modules/@mandrel/agents
# by `mandrel sync`) would silently hide newly added framework `.agents/**`
# source files from `git status`/`git add`. Consumer projects add the
# `/.agents/` ignore to their OWN .gitignore; the framework repo must not.
# Local overrides under .agents/ are still ignored below.

# Agent Local Overrides
.agentrc.local.json
.agents/*.local.md
.agents/*local.json

# Agent local-additions zone (Story #3498, f-drift-local-zone).
# `.agents/local/` is the consumer-owned, sync-exempt space for hand-authored
# additions: `mandrel sync` never writes into nor prunes it, so files placed
# there survive every re-materialization. Consumers SHOULD commit their
# `.agents/local/` additions to source control — this convention is documented
# here intentionally WITHOUT an ignore rule so those additions stay tracked.
# (In this framework repo the entire `/.agents/` working copy is ignored above
# because it is regenerated from the package payload; the convention is for
# downstream consumer projects that vendor `.agents/` via `mandrel sync`.)

tmp/
temp/

# Coverage artefacts (regenerated by `npm run test:coverage`; CRAP gate reads them)
coverage/
.v8-coverage/

# Generated Claude Code commands (source of truth: .agents/workflows/)
.claude/commands/
# Personal Claude Code overrides (team-shared config lives in .claude/settings.json)
.claude/settings.local.json
# Runtime lock files (per-process mutexes carrying sessionId/pid/timestamp)
.claude/*.lock

.mcp.json

.worktrees