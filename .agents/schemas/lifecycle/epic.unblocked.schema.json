{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/dsj1984/mandrel/blob/main/.agents/schemas/lifecycle/epic.unblocked.schema.json",
  "title": "epic.unblocked",
  "description": "Emitted by BlockerHandler when the Epic returns to agent::executing after operator unblock.",
  "type": "object",
  "required": ["reason"],
  "properties": {
    "reason": { "type": "string", "minLength": 1 },
    "sourceStoryId": { "type": "integer", "minimum": 1 }
  },
  "additionalProperties": false
}
