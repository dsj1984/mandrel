{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dispatch-manifest",
  "title": "Dispatch Manifest",
  "description": "Output of dispatcher.js (epic-dispatch variant) and orchestration/story-executor.js (story-execution variant). Written to temp/dispatch-manifest-<epicId>.json for the epic-dispatch variant. The two variants are discriminated by the `type` field. Open-root by design — the AJV fixture drift test is the enforcement boundary; see docs/decisions.md ADR 20260427-868a.",
  "type": "object",
  "required": ["generatedAt", "dryRun"],
  "properties": {
    "type": {
      "type": "string",
      "enum": ["epic-dispatch", "story-execution"],
      "description": "Discriminator for the manifest variant."
    },
    "schemaVersion": {
      "type": "string",
      "description": "Schema version for forward-compatibility checks. Emitted by the epic-dispatch variant.",
      "examples": ["1.0.0"]
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp when this manifest was produced."
    },
    "epicId": {
      "type": "integer",
      "minimum": 1,
      "description": "GitHub Issue number of the Epic."
    },
    "epicTitle": {
      "type": "string",
      "description": "Title of the Epic issue."
    },
    "executor": {
      "type": "string",
      "description": "The IExecutionAdapter executorId used for this dispatch cycle.",
      "examples": ["manual", "subprocess", "mcp"]
    },
    "dryRun": {
      "type": "boolean",
      "description": "If true, no branches were created and no tasks were dispatched."
    },
    "protocolVersionMismatch": {
      "type": "boolean",
      "description": "True if any task's generation-time protocol version differs from the current runtime version."
    },
    "agentTelemetry": {
      "type": ["object", "null"],
      "description": "Optional runtime telemetry attached by the executor. Open-shape: any executor-defined fields are allowed.",
      "additionalProperties": true
    },
    "summary": {
      "type": "object",
      "required": [
        "totalTasks",
        "doneTasks",
        "progressPercent",
        "totalWaves",
        "dispatched"
      ],
      "properties": {
        "totalTasks": {
          "type": "integer",
          "minimum": 0
        },
        "doneTasks": {
          "type": "integer",
          "minimum": 0
        },
        "progressPercent": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "totalWaves": {
          "type": "integer",
          "minimum": 0
        },
        "dispatched": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of tasks dispatched in this invocation."
        }
      },
      "additionalProperties": false
    },
    "waves": {
      "type": "array",
      "description": "Ordered list of execution waves computed from the task DAG.",
      "items": {
        "type": "object",
        "required": ["waveIndex", "tasks"],
        "properties": {
          "waveIndex": {
            "type": "integer",
            "minimum": 0
          },
          "tasks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "taskId",
                "title",
                "status",
                "branch",
                "persona",
                "mode",
                "skills",
                "focusAreas",
                "dependsOn"
              ],
              "properties": {
                "taskId": { "type": "integer", "minimum": 1 },
                "title": { "type": "string" },
                "status": {
                  "type": "string",
                  "enum": [
                    "agent::ready",
                    "agent::executing",
                    "agent::done",
                    "status::blocked"
                  ]
                },
                "branch": { "type": "string" },
                "persona": { "type": "string" },
                "mode": {
                  "type": "string",
                  "enum": ["fast", "planning"]
                },
                "skills": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "focusAreas": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "dependsOn": {
                  "type": "array",
                  "items": { "type": "integer" }
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "dispatched": {
      "type": "array",
      "description": "Tasks dispatched during this invocation.",
      "items": {
        "type": "object",
        "required": ["taskId", "dispatchId", "status"],
        "properties": {
          "taskId": { "type": "integer", "minimum": 1 },
          "dispatchId": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["dispatched", "queued"]
          }
        },
        "additionalProperties": false
      }
    },
    "storyManifest": {
      "type": "array",
      "description": "Story-centric grouping of tasks. Each entry represents a Story (or Feature/ungrouped fallback) with its branch and child tasks. This is the primary execution unit — operators dispatch at the Story level.",
      "items": {
        "type": "object",
        "required": [
          "storyId",
          "storyTitle",
          "storySlug",
          "type",
          "branchName",
          "earliestWave",
          "tasks"
        ],
        "properties": {
          "storyId": {
            "oneOf": [
              { "type": "integer", "minimum": 1 },
              { "type": "string", "const": "__ungrouped__" }
            ],
            "description": "GitHub Issue number of the parent Story (or Feature, when a Task is parented directly to a Feature), or '__ungrouped__' for orphan tasks."
          },
          "storyTitle": {
            "type": "string",
            "description": "Title of the parent Story/Feature issue, or '(Ungrouped Tasks)' for orphans."
          },
          "storySlug": {
            "type": "string",
            "description": "URL-safe slug derived from the Story title."
          },
          "type": {
            "type": "string",
            "enum": ["story", "feature", "ungrouped"],
            "description": "Group classification: 'story' for Story-parented tasks, 'feature' for tasks parented directly to a Feature, 'ungrouped' for orphans."
          },
          "branchName": {
            "type": "string",
            "description": "Git branch name for this Story (e.g., story-868)."
          },
          "earliestWave": {
            "type": "integer",
            "description": "The earliest wave index any task in this story appears in. Stories in the same wave can run in parallel."
          },
          "tasks": {
            "type": "array",
            "description": "Child tasks belonging to this Story, executed sequentially on the Story branch.",
            "items": {
              "type": "object",
              "required": [
                "taskId",
                "taskSlug",
                "parentSlug",
                "status",
                "dependencies"
              ],
              "properties": {
                "taskId": { "type": "integer", "minimum": 1 },
                "taskSlug": { "type": "string" },
                "parentSlug": { "type": "string" },
                "status": { "type": "string" },
                "dependencies": {
                  "type": "array",
                  "items": { "type": "integer" }
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "stories": {
      "type": "array",
      "description": "Story-execution variant payload — one entry per Story this manifest covers.",
      "items": {
        "type": "object",
        "required": ["storyId", "storyTitle", "branchName", "tasks"],
        "properties": {
          "storyId": { "type": "integer", "minimum": 1 },
          "storyTitle": { "type": "string" },
          "epicId": {
            "type": ["integer", "null"],
            "minimum": 1
          },
          "epicBranch": { "type": ["string", "null"] },
          "branchName": { "type": "string" },
          "tasks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["taskId", "title", "status"],
              "properties": {
                "taskId": { "type": "integer", "minimum": 1 },
                "title": { "type": "string" },
                "status": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "oneOf": [
    {
      "title": "epic-dispatch variant",
      "description": "Output of dispatcher.js / buildManifest(). The `type` field may be absent for back-compat; presence is restricted to 'epic-dispatch'.",
      "properties": {
        "type": { "const": "epic-dispatch" }
      },
      "required": [
        "schemaVersion",
        "epicId",
        "epicTitle",
        "executor",
        "summary",
        "waves",
        "storyManifest",
        "dispatched"
      ],
      "not": { "required": ["stories"] }
    },
    {
      "title": "story-execution variant",
      "description": "Output of orchestration/story-executor.js / executeStory().",
      "properties": {
        "type": { "const": "story-execution" }
      },
      "required": ["type", "stories"]
    }
  ]
}
