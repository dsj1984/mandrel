{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/dsj1984/agent-protocols/blob/main/.agents/schemas/agentrc.schema.json",
  "title": "Agent Protocols .agentrc",
  "description": "Static JSON Schema mirror of the authoritative AJV schemas in .agents/scripts/lib/config-schema.js + config-settings-schema.js. The AJV schemas are the runtime source of truth; this file exists for editor tooling and human readers. A drift test (tests/config-schema-mirror-drift.test.js) keeps the two in sync.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "agentSettings": { "$ref": "#/$defs/agentSettings" },
    "orchestration": { "$ref": "#/$defs/orchestration" }
  },
  "$defs": {
    "safeString": {
      "type": "string",
      "not": { "pattern": "([;&|`]|\\$\\()" }
    },
    "nullableSafeString": {
      "type": ["string", "null"],
      "not": { "type": "string", "pattern": "([;&|`]|\\$\\()" }
    },
    "listOrExtenderOfStrings": {
      "oneOf": [
        { "type": "array", "items": { "type": "string" } },
        {
          "type": "object",
          "properties": {
            "append": { "type": "array", "items": { "type": "string" } },
            "prepend": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        }
      ]
    },
    "maintainabilityCrap": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "targetDirs": { "$ref": "#/$defs/listOrExtenderOfStrings" },
        "newMethodCeiling": { "type": "integer", "minimum": 1 },
        "coveragePath": {
          "allOf": [
            { "$ref": "#/$defs/safeString" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "tolerance": { "type": "number", "minimum": 0 },
        "requireCoverage": { "type": "boolean" },
        "friction": {
          "type": "object",
          "properties": { "markerKey": { "type": "string", "minLength": 1 } },
          "additionalProperties": false
        },
        "refreshTag": {
          "allOf": [
            { "$ref": "#/$defs/safeString" },
            { "type": "string", "minLength": 1 }
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "enabled": { "const": true },
              "requireCoverage": { "const": true }
            },
            "required": ["enabled", "requireCoverage"]
          },
          "then": { "required": ["coveragePath"] }
        }
      ]
    },
    "release": {
      "type": "object",
      "properties": {
        "docs": {
          "type": "array",
          "items": {
            "allOf": [
              { "$ref": "#/$defs/safeString" },
              { "type": "string", "minLength": 1 }
            ]
          }
        },
        "versionFile": { "$ref": "#/$defs/nullableSafeString" },
        "packageJson": { "type": "boolean" },
        "autoVersionBump": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "frictionLimits": {
      "type": "object",
      "properties": {
        "repetitiveCommandCount": { "type": "integer", "minimum": 1 },
        "consecutiveErrorCount": { "type": "integer", "minimum": 1 },
        "stagnationStepCount": { "type": "integer", "minimum": 1 },
        "maxIntegrationRetries": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "signalsLimits": {
      "type": "object",
      "description": "Detector thresholds for the performance-signal taxonomy (Epic #1030). All nested blocks are optional; the resolver fills missing keys from framework defaults.",
      "properties": {
        "hotspot": {
          "type": "object",
          "properties": {
            "p95Multiplier": { "type": "number", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "rework": {
          "type": "object",
          "properties": {
            "editsPerFile": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": false
        },
        "churn": {
          "type": "object",
          "properties": {
            "repeatCount": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": false
        },
        "idle": {
          "type": "object",
          "properties": {
            "gapSeconds": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": false
        },
        "retry": {
          "type": "object",
          "properties": {
            "repeatCount": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "planningContextLimits": {
      "type": "object",
      "properties": {
        "maxBytes": { "type": "integer", "minimum": 1024 },
        "summaryMode": {
          "type": "string",
          "enum": ["auto", "always", "never"]
        }
      },
      "additionalProperties": false
    },
    "limits": {
      "type": "object",
      "properties": {
        "maxInstructionSteps": { "type": "integer", "minimum": 1 },
        "maxTickets": { "type": "integer", "minimum": 1 },
        "maxTokenBudget": { "type": "integer", "minimum": 1 },
        "executionTimeoutMs": { "type": "integer", "minimum": 1 },
        "executionMaxBuffer": { "type": "integer", "minimum": 1 },
        "friction": { "$ref": "#/$defs/frictionLimits" },
        "planningContext": { "$ref": "#/$defs/planningContextLimits" },
        "signals": { "$ref": "#/$defs/signalsLimits" }
      },
      "additionalProperties": false
    },
    "planning": {
      "type": "object",
      "properties": {
        "riskHeuristics": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "prGate": {
      "type": "object",
      "properties": {
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "cmd"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "cmd": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              }
            },
            "additionalProperties": false
          }
        },
        "enforceBranchProtection": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "maintainabilityQuality": {
      "type": "object",
      "properties": {
        "targetDirs": { "$ref": "#/$defs/listOrExtenderOfStrings" }
      },
      "additionalProperties": false
    },
    "nullableNonemptySafeString": {
      "type": ["string", "null"],
      "minLength": 1,
      "not": { "type": "string", "pattern": "([;&|`]|\\$\\()" }
    },
    "commands": {
      "type": "object",
      "properties": {
        "validate": {
          "allOf": [
            { "$ref": "#/$defs/safeString" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "lintBaseline": {
          "allOf": [
            { "$ref": "#/$defs/safeString" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "test": {
          "allOf": [
            { "$ref": "#/$defs/safeString" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "typecheck": { "$ref": "#/$defs/nullableNonemptySafeString" },
        "build": { "$ref": "#/$defs/nullableNonemptySafeString" },
        "formatCheck": {
          "allOf": [
            { "$ref": "#/$defs/safeString" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "formatWrite": {
          "allOf": [
            { "$ref": "#/$defs/safeString" },
            { "type": "string", "minLength": 1 }
          ]
        }
      },
      "additionalProperties": false
    },
    "baselineEntry": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path": {
          "allOf": [
            { "$ref": "#/$defs/safeString" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "refreshCommand": { "$ref": "#/$defs/nullableNonemptySafeString" }
      },
      "additionalProperties": false
    },
    "quality": {
      "type": "object",
      "properties": {
        "baselines": {
          "type": "object",
          "properties": {
            "lint": { "$ref": "#/$defs/baselineEntry" },
            "crap": { "$ref": "#/$defs/baselineEntry" },
            "maintainability": { "$ref": "#/$defs/baselineEntry" }
          },
          "additionalProperties": false
        },
        "maintainability": { "$ref": "#/$defs/maintainabilityQuality" },
        "crap": { "$ref": "#/$defs/maintainabilityCrap" },
        "prGate": { "$ref": "#/$defs/prGate" }
      },
      "additionalProperties": false
    },
    "paths": {
      "type": "object",
      "required": ["agentRoot", "docsRoot", "tempRoot"],
      "properties": {
        "agentRoot": {
          "allOf": [
            { "$ref": "#/$defs/safeString" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "docsRoot": {
          "allOf": [
            { "$ref": "#/$defs/safeString" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "tempRoot": {
          "allOf": [
            { "$ref": "#/$defs/safeString" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "auditOutputDir": {
          "allOf": [
            { "$ref": "#/$defs/safeString" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "scriptsRoot": {
          "allOf": [
            { "$ref": "#/$defs/safeString" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "workflowsRoot": {
          "allOf": [
            { "$ref": "#/$defs/safeString" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "personasRoot": {
          "allOf": [
            { "$ref": "#/$defs/safeString" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "schemasRoot": {
          "allOf": [
            { "$ref": "#/$defs/safeString" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "skillsRoot": {
          "allOf": [
            { "$ref": "#/$defs/safeString" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "templatesRoot": {
          "allOf": [
            { "$ref": "#/$defs/safeString" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "rulesRoot": {
          "allOf": [
            { "$ref": "#/$defs/safeString" },
            { "type": "string", "minLength": 1 }
          ]
        }
      },
      "additionalProperties": false
    },
    "agentSettings": {
      "type": "object",
      "required": ["paths"],
      "properties": {
        "baseBranch": { "$ref": "#/$defs/safeString" },
        "docsContextFiles": { "type": "array", "items": { "type": "string" } },
        "release": { "$ref": "#/$defs/release" },
        "planning": { "$ref": "#/$defs/planning" },
        "quality": { "$ref": "#/$defs/quality" },
        "commands": { "$ref": "#/$defs/commands" },
        "paths": { "$ref": "#/$defs/paths" },
        "limits": { "$ref": "#/$defs/limits" }
      },
      "additionalProperties": false
    },
    "github": {
      "type": "object",
      "required": ["owner", "repo"],
      "properties": {
        "owner": { "type": "string", "minLength": 1 },
        "repo": { "type": "string", "minLength": 1 },
        "projectNumber": { "type": ["integer", "null"], "minimum": 1 },
        "projectOwner": { "type": ["string", "null"], "minLength": 1 },
        "projectName": { "type": ["string", "null"], "minLength": 1 },
        "operatorHandle": { "type": "string", "pattern": "^@.+" }
      },
      "additionalProperties": false
    },
    "notifications": {
      "type": "object",
      "properties": {
        "mentionOperator": { "type": "boolean" },
        "commentEvents": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["state-transition", "story-merged", "operator-message"]
          },
          "uniqueItems": true
        },
        "webhookEvents": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "epic-started",
              "epic-progress",
              "epic-blocked",
              "epic-unblocked",
              "epic-complete"
            ]
          },
          "uniqueItems": true
        }
      },
      "required": ["commentEvents", "webhookEvents"],
      "additionalProperties": false
    },
    "worktreeIsolation": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "root": { "type": "string", "minLength": 1 },
        "nodeModulesStrategy": {
          "type": "string",
          "enum": ["per-worktree", "symlink", "pnpm-store"]
        },
        "primeFromPath": { "type": ["string", "null"], "minLength": 1 },
        "allowSymlinkOnWindows": { "type": "boolean" },
        "reapOnSuccess": { "type": "boolean" },
        "reapOnCancel": { "type": "boolean" },
        "windowsPathLengthWarnThreshold": { "type": "integer", "minimum": 1 },
        "bootstrapFiles": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": { "enabled": { "const": true } },
            "required": ["enabled"]
          },
          "then": { "required": ["root"] }
        }
      ]
    },
    "deliverRunner": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "concurrencyCap": { "type": "integer", "minimum": 1 },
        "progressReportIntervalSec": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "not": {
              "properties": { "enabled": { "const": false } },
              "required": ["enabled"]
            }
          },
          "then": { "required": ["concurrencyCap"] }
        }
      ]
    },
    "planRunner": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "pollIntervalSec": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "concurrency": {
      "type": "object",
      "properties": {
        "waveGate": { "type": "integer", "minimum": 0 },
        "commitAssertion": { "type": "integer", "minimum": 1 },
        "progressReporter": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "storyMergeRetry": {
      "type": "object",
      "properties": {
        "maxAttempts": { "type": "integer", "minimum": 1 },
        "backoffMs": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 }
        }
      },
      "additionalProperties": false
    },
    "decomposer": {
      "type": "object",
      "properties": {
        "concurrencyCap": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "runners": {
      "type": "object",
      "properties": {
        "deliverRunner": { "$ref": "#/$defs/deliverRunner" },
        "planRunner": { "$ref": "#/$defs/planRunner" },
        "concurrency": { "$ref": "#/$defs/concurrency" },
        "storyMergeRetry": { "$ref": "#/$defs/storyMergeRetry" },
        "decomposer": { "$ref": "#/$defs/decomposer" }
      },
      "additionalProperties": false
    },
    "orchestration": {
      "type": "object",
      "required": ["provider"],
      "properties": {
        "provider": { "type": "string", "enum": ["github"] },
        "github": { "$ref": "#/$defs/github" },
        "executor": { "type": "string" },
        "notifications": { "$ref": "#/$defs/notifications" },
        "worktreeIsolation": { "$ref": "#/$defs/worktreeIsolation" },
        "runners": { "$ref": "#/$defs/runners" }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": { "provider": { "const": "github" } },
            "required": ["provider"]
          },
          "then": { "required": ["github"] }
        }
      ]
    }
  }
}
